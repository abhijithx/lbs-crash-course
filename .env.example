# Internal Security
ADMIN_API_SECRET= # Used to secure admin-only API calls
MEDIA_TOKEN_SECRET= # Required: HMAC secret for signing media tokens (generate with: openssl rand -hex 32)NEXT_PUBLIC_REGISTRATION_SECRET=your_secure_registration_secret_here
